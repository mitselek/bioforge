{
  "name": "bioforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Terminal-based ecosystem simulation with Turing-machine genomes",
  "scripts": {
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint --no-error-on-unmatched-pattern 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --no-error-on-unmatched-pattern --write 'src/**/*.ts' 'tests/**/*.ts' '*.json'",
    "format:check": "prettier --no-error-on-unmatched-pattern --check 'src/**/*.ts' 'tests/**/*.ts' '*.json'",
    "dev": "npx tsx src/run.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "blessed": "^0.1.81"
  }
}
